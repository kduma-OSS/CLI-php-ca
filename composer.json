{
    "name": "kduma/php-ca",
    "description": "GIT Flow tools for Laravel ",
    "keywords": ["kduma","certificate authority","ca"],
    "homepage": "https://github.com/kduma-OSS/CLI-php-ca",
    "type": "project",
    "license": "MIT",
    "support": {
        "issues": "https://github.com/kduma-OSS/CLI-php-ca/issues",
        "source": "https://github.com/kduma-OSS/CLI-php-ca"
    },
    "authors": [
        {
            "name": "Krystian Duma",
            "email": "git@krystian.duma.sh"
        }
    ],
    "require": {
        "php": "^8.4",
        "laravel-zero/framework": "^12.0.2",
        "phpseclib/phpseclib": "^3.0"
    },
    "require-dev": {
        "kduma/git-flow-tool": "^0.0.5",
        "laravel/pint": "^1.25.1",
        "mockery/mockery": "^1.6.12",
        "pestphp/pest": "^3.8.4|^4.1.2",
        "phpacker/phpacker": "^0.6.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "bin": ["php-ca"]
}
