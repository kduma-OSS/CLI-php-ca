{
    "database_path": "./db/sub-ca",
    "certification_authority": {
        "random_serial_numbers": false,
        "distinguished_name": "C=WW, O=PHP PKI CA Project, CN=My Sub CA",
        "certificate_distribution_points": [
            "http://pki.example.com/sub-ca.crt",
            "http://pki-alt.example.com/sub-ca.crt"
        ],
        "crl_distribution_points": [
            "http://pki.example.com/sub-ca.crl",
            "http://pki-alt.example.com/sub-ca.crl"
        ]
    },
    "certificate_templates": {
        "end-entity": {
            "ca": false,
            "path_length_constraint": null,
            "validity": "+1 years"
        },
        "intermediate-ca": {
            "ca": true,
            "path_length_constraint": 0,
            "validity": "+10 years"
        }
    }
}
