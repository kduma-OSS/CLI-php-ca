{
    "name": "kduma/php-ca-config-manager",
    "description": "PHP Certification Authority - Configuration Manager",
    "keywords": [
        "certificate-authority",
        "pki"
    ],
    "homepage": "https://opensource.duma.sh/apps/php-ca",
    "license": "MIT",
    "authors": [
        {
            "name": "Krystian Duma",
            "email": "git@krystian.duma.sh"
        }
    ],
    "type": "library",
    "require": {
        "php": "^8.4",
        "kduma/php-ca-contracts": "dev-master",
        "kduma/php-ca-lib": "dev-master",
        "kduma/simple-dal-encryption": "^v0.2",
        "kduma/simple-dal-encryption-phpseclib": "^v0.2",
        "kduma/simple-dal-encryption-sodium": "^v0.2",
        "kduma/simple-dal-integrity": "^v0.2",
        "kduma/simple-dal-integrity-contracts": "^v0.2",
        "kduma/simple-dal-integrity-hash": "^v0.2",
        "kduma/simple-dal-integrity-phpseclib": "^v0.2",
        "kduma/simple-dal-integrity-sodium": "^v0.2",
        "kduma/simple-dal-db-adapter": "^v0.2",
        "kduma/simple-dal-flysystem-adapter": "^v0.2",
        "league/flysystem": "^3.32",
        "league/flysystem-ziparchive": "^3.31",
        "phpseclib/phpseclib": "^3.0.50",
        "spatie/php-attribute-reader": "^1.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0|^4.4.2"
    },
    "autoload": {
        "psr-4": {
            "KDuma\\PhpCA\\ConfigManager\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "KDuma\\PhpCA\\ConfigManager\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "0.0-dev"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
