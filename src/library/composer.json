{
    "name": "kduma/php-ca-lib",
    "description": "PHP Certification Authority - Core Library",
    "keywords": [
        "certificate-authority",
        "pki"
    ],
    "homepage": "https://opensource.duma.sh/apps/php-ca",
    "license": "MIT",
    "authors": [
        {
            "name": "Krystian Duma",
            "email": "git@krystian.duma.sh"
        }
    ],
    "type": "library",
    "require": {
        "php": "^8.4",
        "kduma/php-ca-contracts": "dev-master",
        "kduma/simple-dal": "^v0.2",
        "kduma/simple-dal-adapter-contracts": "^v0.2",
        "kduma/simple-dal-typed": "^v0.2",
        "phpseclib/phpseclib": "^3.0.50"
    },
    "require-dev": {
        "pestphp/pest": "^3.0|^4.4.2"
    },
    "autoload": {
        "psr-4": {
            "KDuma\\PhpCA\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "KDuma\\PhpCA\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "0.0-dev"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
