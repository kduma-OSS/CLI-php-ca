{
    "name": "kduma/php-ca",
    "description": "PHP Certification Authority - CLI",
    "keywords": [
        "certificate-authority",
        "pki",
        "cli"
    ],
    "homepage": "https://opensource.duma.sh/apps/php-ca",
    "license": "MIT",
    "authors": [
        {
            "name": "Krystian Duma",
            "email": "git@krystian.duma.sh"
        }
    ],
    "type": "project",
    "require": {
        "php": "^8.4",
        "kduma/php-ca-config-manager": "^0.1.0",
        "kduma/php-ca-lib": "^0.1.0",
        "laravel-zero/framework": "^12.0.5",
        "paragonie/sodium_compat": "^2.5",
        "phpseclib/phpseclib": "^3.0.50"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "mockery/mockery": "^1.6.12",
        "pestphp/pest": "^3.0|^4.4.2",
        "phpacker/phpacker": "^0.6.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files": [
            "app/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "0.0-dev"
        }
    },
    "bin": [
        "php-ca"
    ],
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "support": {
        "issues": "https://github.com/kduma-OSS/PHP-CA/issues",
        "source": "https://github.com/kduma-OSS/PHP-CA"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
